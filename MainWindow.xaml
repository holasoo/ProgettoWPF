<Window x:Class="ProgettoWPFReguig.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Master 4.0" Height="650" Width="900">

    <Grid>
        <!-- SFONDO SFUMATO BLU -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#000428" Offset="0"/>
                <GradientStop Color="#004e92" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- EMOJI DI SFONDO -->
        <Canvas Opacity="0.1" IsHitTestVisible="False">
            <TextBlock Text="🏋️" FontSize="150" Canvas.Left="50" Canvas.Top="50"/>
            <TextBlock Text="💪" FontSize="120" Canvas.Right="100" Canvas.Bottom="100"/>
        </Canvas>

        <StackPanel Margin="30">
            <TextBlock Text="FITNESS TRACKER 🚀" FontSize="36" FontWeight="Bold" Foreground="Cyan" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- FORM INSERIMENTO -->
            <Border Background="#33FFFFFF" CornerRadius="15" Padding="20" BorderBrush="White" BorderThickness="1">
                <UniformGrid Columns="3">
                    <StackPanel Margin="5">
                        <TextBlock Text="Nome Esercizio" Foreground="White"/>
                        <TextBox x:Name="TxtNome" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Serie" Foreground="White"/>
                        <TextBox x:Name="TxtSerie" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Ripetizioni" Foreground="White"/>
                        <TextBox x:Name="TxtReps" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Peso (kg)" Foreground="White"/>
                        <TextBox x:Name="TxtPeso" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Minuti Cardio (opzionale)" Foreground="Yellow"/>
                        <TextBox x:Name="TxtMinuti" Margin="0,5" Background="#55FFFF00"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnAggiungi" Content="AGGIUNGI 💪" Click="BtnAggiungi_Click" Width="100" Height="40" Background="LimeGreen" FontWeight="Bold" Margin="5"/>
                        <Button x:Name="BtnAnnulla" Content="ANNULLA ↩️" Click="BtnAnnulla_Click" Width="100" Height="40" Background="OrangeRed" FontWeight="Bold" Margin="5"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- LISTA RISULTATI clarence gozzi -->
            <ListView x:Name="LstEsercizi" Margin="0,30,0,0" Height="250" Background="#22FFFFFF" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="5" CornerRadius="8" Padding="15" Width="750">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" Margin="0,0,10,0"/>
                                <!-- Binding al metodo polimorfico tramite la proprietà o il metodo -->
                                <TextBlock Text="{Binding}" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Window>