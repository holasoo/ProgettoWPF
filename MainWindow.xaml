<Window x:Class="ProgettoWPFReguig.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Master 4.0" Height="720" Width="1050" Background="#121212">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="GYM MASTER" FontSize="40" FontWeight="Bold" Foreground="Cyan" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLONNA SINISTRA -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Border Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="Cyan" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="OBIETTIVO" Foreground="Cyan" FontWeight="Bold"/>
                        <ComboBox x:Name="CmbObiettivo" SelectedIndex="0" Margin="0,5">
                            <ComboBoxItem Content="Ipertrofia"/>
                            <ComboBoxItem Content="Forza"/>
                            <ComboBoxItem Content="Resistenza"/>
                        </ComboBox>
                        <TextBlock Text="GRUPPO MUSCOLARE" Foreground="White" Margin="0,10,0,0"/>
                        <ComboBox x:Name="CmbGruppo" Margin="0,5" SelectionChanged="CmbGruppo_SelectionChanged"/>
                        <TextBlock Text="ESERCIZIO" Foreground="White" Margin="0,10,0,0"/>
                        <ComboBox x:Name="CmbEsercizi" Margin="0,5,0,10"/>
                        <Button Content="INIZIA ESERCIZIO" Background="Lime" Click="BtnAvviaEsercizio_Click" FontWeight="Bold" Height="30"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="10" Padding="15" BorderBrush="Orange" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="REGISTRA DATI" Foreground="Orange" FontWeight="Bold" Margin="0,0,0,10"/>

                        <UniformGrid x:Name="PanelPesi" Columns="2" Visibility="Visible">
                            <StackPanel Margin="5">
                                <TextBlock Text="Peso kg" Foreground="White"/>
                                <TextBox x:Name="TxtPeso" Text="0" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock Text="Reps" Foreground="White"/>
                                <TextBox x:Name="TxtReps" Text="0" FontSize="16"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel x:Name="PanelCardio" Visibility="Collapsed">
                            <UniformGrid Columns="3">
                                <StackPanel Margin="2">
                                    <TextBlock Text="Min" Foreground="White"/>
                                    <TextBox x:Name="TxtMinuti" Text="0"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Km/h" Foreground="White"/>
                                    <TextBox x:Name="TxtVel" Text="0"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Incl %" Foreground="White"/>
                                    <TextBox x:Name="TxtIncl" Text="0"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>

                        <Button Content="AGGIUNGI SERIE 💪" Background="Orange" Margin="0,15,0,0" Height="40" Click="BtnAggiungiSerie_Click" FontWeight="Bold"/>

                        <Border x:Name="BrdFeedback" Background="#33FFA500" Visibility="Collapsed" Margin="0,10,0,0" Padding="10">
                            <TextBlock x:Name="TxtFeedback" Foreground="Orange" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- COLONNA DESTRA -->
            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="10" Padding="15">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Content="FINE ALLENAMENTO 🏆" Background="Cyan" FontWeight="Bold" Height="45" Click="BtnFineAllenamento_Click"/>

                        <!-- AGGIUNTO: Tasto per la PILA (Stack) -->
                        <Button Content="Annulla Ultimo ↩️" Background="#444" Foreground="White" Height="30" Margin="0,5" Click="BtnAnnullaUltimo_Click"/>

                        <Button Content="Svuota Sessione" Background="Transparent" Foreground="Red" Click="BtnAnnulla_Click" Margin="0,5,0,0"/>
                    </StackPanel>
                    <ListView x:Name="LstEsercizi" Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D2D" Margin="0,0,0,10" CornerRadius="8" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nome}" FontSize="18" FontWeight="Bold" Foreground="Cyan"/>
                                            <TextBlock Text="{Binding GruppoMuscolare}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding}" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>